<!-- ══════════════════════════════════════════
     PARTIAL: chat-widget.hbs
     Chat flotante con emojis + grupos
══════════════════════════════════════════ -->
<div class="chatw" id="chatw">

  <!-- ── Barra colapsada ── -->
  <button class="chatw-bar" id="chatwBar" onclick="ChatWidget.toggle()">
    <i data-lucide="message-circle"></i>
    <span class="chatw-bar-label">Chat</span>
    <span class="chatw-badge" id="chatwBadgeBar" style="display:none">0</span>
    <i data-lucide="chevron-up" class="chatw-chevron"></i>
  </button>

  <!-- ── Panel principal ── -->
  <div class="chatw-panel" id="chatwPanel" style="display:none">

    <!-- Header -->
    <div class="chatw-header">
      <span class="chatw-header-title">
        <i data-lucide="message-circle"></i>
        <span id="chatwHeaderLabel">Chat</span>
      </span>
      <div class="chatw-header-actions">
        <!-- Botón volver (visible en conversación) -->
        <button class="chatw-icon-btn" id="chatwBackBtn"
                onclick="ChatWidget.volverALista()" style="display:none" title="Volver">
          <i data-lucide="arrow-left"></i>
        </button>
        <!-- Botón info grupo (visible en conversación de grupo) -->
        <button class="chatw-icon-btn" id="chatwGrupoInfoBtn"
                onclick="ChatWidget.toggleInfoGrupo()" style="display:none" title="Info del grupo">
          <i data-lucide="info"></i>
        </button>
        <!-- Botón crear grupo (visible en la lista) -->
        <button class="chatw-icon-btn" id="chatwNuevoGrupoBtn"
                onclick="ChatWidget.abrirModalGrupo()" title="Nuevo grupo">
          <i data-lucide="users-round"></i>
        </button>
        <!-- Minimizar -->
        <button class="chatw-icon-btn" onclick="ChatWidget.toggle()" title="Minimizar">
          <i data-lucide="minus"></i>
        </button>
      </div>
    </div>

    <!-- ── Vista lista contactos + grupos ── -->
    <div class="chatw-body" id="chatwListaView">
      <div class="chatw-contactos" id="chatwContactos">
        <div class="chatw-empty">
          <i data-lucide="loader-2" class="chatw-spin"></i>
          <span>Cargando...</span>
        </div>
      </div>
    </div>

    <!-- ── Vista conversación 1-a-1 / grupo ── -->
    <div class="chatw-body chatw-body-conv" id="chatwConvView" style="display:none">
      <div class="chatw-conv-header" id="chatwConvHeader"></div>

      <!-- Panel info del grupo (oculto por defecto) -->
      <div class="chatw-grupo-info" id="chatwGrupoInfo" style="display:none">
        <p class="chatw-grupo-info-titulo">Miembros del grupo</p>
        <div id="chatwGrupoMiembros"></div>
        <button class="chatw-grupo-salir-btn" id="chatwEliminarGrupoBtn"
                onclick="ChatWidget.eliminarGrupo()" style="display:none">
          <i data-lucide="trash-2"></i> Eliminar grupo
        </button>
      </div>

      <div class="chatw-mensajes" id="chatwMensajes"></div>

      <!-- Input con emoji y enviar -->
      <!-- IMPORTANTE: el panel de emojis vive DENTRO de este form
           para que se posicione relativo a la barra de texto
           (que tiene position:relative), no al chat completo.
           Si se mueve afuera, el panel "desaparece" porque el
           chat tiene overflow:hidden y lo recorta. -->
      <form class="chatw-input-row" id="chatwForm"
            onsubmit="return ChatWidget.enviarMensaje(event)">
        <!-- Botón emoji -->
        <button type="button" class="chatw-emoji-btn"
                onclick="ChatWidget.toggleEmojis(event)" title="Emojis">
          <i data-lucide="smile"></i>
        </button>
        <input type="text" id="chatwInput"
               placeholder="Escribe un mensaje..."
               autocomplete="off" maxlength="2000" />
        <button type="submit" class="chatw-send-btn" title="Enviar">
          <i data-lucide="send"></i>
        </button>

        <!-- Panel de emojis (oculto por defecto) -->
        <div class="chatw-emoji-panel" id="chatwEmojiPanel" style="display:none"></div>
      </form>
    </div>

  </div>
</div>

<!-- ── Modal crear grupo ── -->
<div class="chatw-modal-backdrop" id="chatwModalGrupo" style="display:none"
     onclick="ChatWidget.cerrarModalGrupo(event)">
  <div class="chatw-modal">
    <div class="chatw-modal-header">
      <span><i data-lucide="users-round"></i> Nuevo grupo</span>
      <button onclick="ChatWidget.cerrarModalGrupo()" class="chatw-icon-btn-dark">
        <i data-lucide="x"></i>
      </button>
    </div>
    <div class="chatw-modal-body">
      <div class="chatw-modal-field">
        <label>Nombre del grupo *</label>
        <input type="text" id="grupoNombre" placeholder="Ej: Equipo Operaciones"
               maxlength="60" />
      </div>
      <div class="chatw-modal-field">
        <label>Selecciona miembros *</label>
        <div class="chatw-miembros-lista" id="grupoMiembrosLista">
          <div class="chatw-empty" style="padding:1rem">
            <i data-lucide="loader-2" class="chatw-spin"></i>
          </div>
        </div>
      </div>
    </div>
    <div class="chatw-modal-footer">
      <button class="chatw-btn-cancel" onclick="ChatWidget.cerrarModalGrupo()">Cancelar</button>
      <button class="chatw-btn-crear" onclick="ChatWidget.crearGrupo()">
        <i data-lucide="plus"></i> Crear grupo
      </button>
    </div>
  </div>
</div>

<script src="/js/chat-widget.js"></script>
