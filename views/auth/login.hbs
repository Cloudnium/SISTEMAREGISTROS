<!-- ══════════════════════════════════════════
     VIEW: auth/login.hbs
     Login estilo Cloudsoft:
     - Panel izquierdo: formulario blanco limpio
     - Panel derecho: slider de imágenes con overlay morado

     ► IMÁGENES DEL SLIDER:
       Coloca tus imágenes en /public/images/slider/
       y actualiza los background-image en el JS al final
       (busca la variable "slides")
══════════════════════════════════════════ -->
<div class="auth-container">

  <!-- ══ PANEL IZQUIERDO: Formulario ══ -->
  <div class="auth-form-panel">

    <!-- Logo -->
    <div class="auth-logo">
      <!--
        OPCIÓN A (ícono SVG — activo por defecto):
        Cambia data-lucide por el ícono que quieras
      -->
      <div class="auth-logo-icon">
        <i data-lucide="cloud-upload"></i>
      </div>
      <!--
        OPCIÓN B (imagen): descomenta y pon tu archivo en /public/images/logos/
        <img src="/images/logos/logo.png" alt="Logo" class="auth-logo-img" />
      -->
      <div class="auth-logo-text-group">
        <!-- Nombre de tu empresa — edita aquí -->
        <span class="auth-logo-name">Cloudnium</span>
        <!-- Eslogan — edita aquí -->
        <span class="auth-logo-tagline">Tu logística, en buenas manos</span>
      </div>
    </div>

    <!-- Flash de error -->
    {{#if error}}
      {{#each error}}
        <div class="auth-flash-error">
          <i data-lucide="alert-circle"></i>
          <span>{{this}}</span>
        </div>
      {{/each}}
    {{/if}}

    <!-- Título -->
    <h2 class="auth-form-title">Iniciar Sesión</h2>

    <!-- Formulario -->
    <form action="/login" method="POST" id="loginForm" autocomplete="off">

      <!-- Campo: Usuario -->
      <div class="auth-field">
        <label for="identificador" class="auth-field-label">
          <i data-lucide="user"></i> Usuario
        </label>
        <!--
          El campo usuario convierte a MAYÚSCULAS automáticamente
          vía el atributo oninput y el JS al final de este archivo
        -->
        <input
          type="text"
          id="identificador"
          name="identificador"
          class="auth-input"
          placeholder="Tu nombre de usuario"
          autocomplete="off"
          
          required
        />
      </div>

      <!-- Campo: Contraseña -->
      <div class="auth-field">
        <label for="password" class="auth-field-label">
          <i data-lucide="lock"></i> Contraseña
        </label>
        <div class="auth-input-wrapper">
          <input
            type="password"
            id="password"
            name="password"
            class="auth-input"
            placeholder="Tu contraseña"
            autocomplete="current-password"
            required
          />
          <button type="button" class="auth-eye-btn" onclick="toggleAuthPassword()" title="Mostrar contraseña">
            <i data-lucide="eye-off" id="authEyeIcon"></i>
          </button>
        </div>
      </div>

      <!-- Botón de ingreso -->
      <button type="submit" class="auth-submit-btn" id="authSubmitBtn">
        <i data-lucide="log-in"></i>
        Iniciar Sesión
      </button>

    </form>

    <!-- Footer -->
    <div class="auth-footer">
      © 2026 Cloudnium. Todos los derechos reservados.
    </div>

  </div>

  <!-- ══ PANEL DERECHO: Slider de imágenes ══ -->
  <div class="auth-image-panel" id="authSlider">

    <!--
      SLIDES: Agrega o quita slides aquí.
      Para cada slide:
        - data-bg: ruta a tu imagen (pon las fotos en /public/images/slider/)
        - data-tag: etiqueta amarilla pequeña
        - data-title: título grande blanco
        - data-desc: descripción pequeña
      Si no tienes imágenes, el fondo morado igual se ve bien.
    -->
    <div class="auth-slide active"
         data-bg="/images/slider/slide1.jpg"
         data-tag="CONTROL TOTAL"
         data-title="Gestiona tu empresa desde un solo lugar"
         data-desc="Cloudnium integra todas las áreas de tu negocio en una plataforma segura, veloz y fácil de usar.">
    </div>

    <div class="auth-slide"
         data-bg="/images/slider/slide2.jpg"
         data-tag="COMBUSTIBLE"
         data-title="Control total de combustible y flota"
         data-desc="Registra cada carga, monitorea el consumo por placa y genera reportes en segundos.">
    </div>

    <div class="auth-slide"
         data-bg="/images/slider/slide3.jpg"
         data-tag="INVENTARIO"
         data-title="Tu inventario siempre al día"
         data-desc="Entradas, salidas y stock mínimo en tiempo real para que nunca te quedes sin lo que necesitas.">
    </div>

    <!-- Overlay morado decorativo -->
    <div class="auth-slide-overlay"></div>

    <!-- Texto del slide activo (se actualiza via JS) -->
    <div class="auth-slide-content" id="slideContent">
      <span class="auth-slide-tag" id="slideTag"></span>
      <h2 class="auth-slide-title" id="slideTitle"></h2>
      <p class="auth-slide-desc" id="slideDesc"></p>
    </div>

    <!-- Flecha izquierda -->
    <button class="auth-slider-arrow prev" onclick="changeSlide(-1)" aria-label="Anterior">
      <i data-lucide="chevron-left"></i>
    </button>

    <!-- Flecha derecha -->
    <button class="auth-slider-arrow next" onclick="changeSlide(1)" aria-label="Siguiente">
      <i data-lucide="chevron-right"></i>
    </button>

    <!-- Dots indicadores -->
    <div class="auth-slider-dots" id="sliderDots"></div>

  </div><!-- fin auth-image-panel -->

</div><!-- fin auth-container -->

<script>
  // ── Inicializa íconos Lucide ──
  document.addEventListener('DOMContentLoaded', function () {
    if (typeof lucide !== 'undefined') lucide.createIcons();
    initSlider();
  });

  // ── Toggle de contraseña ──
  function toggleAuthPassword() {
    const input = document.getElementById('password');
    const icon  = document.getElementById('authEyeIcon');
    if (input.type === 'password') {
      input.type = 'text';
      icon.setAttribute('data-lucide', 'eye');
    } else {
      input.type = 'password';
      icon.setAttribute('data-lucide', 'eye-off');
    }
    lucide.createIcons();
  }

  // ── Slider de imágenes ──
  let currentSlide = 0;
  let slideInterval = null;
  const slides = document.querySelectorAll('.auth-slide');
  const total  = slides.length;

  function initSlider() {
    if (total === 0) return;

    // Aplica imágenes de fondo a cada slide
    slides.forEach(function(slide) {
      const bg = slide.getAttribute('data-bg');
      if (bg) slide.style.backgroundImage = 'url(' + bg + ')';
      // Si la imagen no carga, el overlay igual cubre bien el fondo sólido
    });

    // Crea los dots indicadores
    const dotsContainer = document.getElementById('sliderDots');
    dotsContainer.innerHTML = '';
    slides.forEach(function(_, i) {
      const dot = document.createElement('button');
      dot.className = 'auth-dot' + (i === 0 ? ' active' : '');
      dot.setAttribute('aria-label', 'Slide ' + (i + 1));
      dot.onclick = function() { goToSlide(i); };
      dotsContainer.appendChild(dot);
    });

    // Muestra el primer slide
    showSlide(0);

    // Auto-avance cada 5 segundos
    slideInterval = setInterval(function() {
      changeSlide(1);
    }, 5000);
  }

  function goToSlide(n) {
    clearInterval(slideInterval);
    showSlide(n);
    slideInterval = setInterval(function() { changeSlide(1); }, 5000);
  }

  function changeSlide(dir) {
    const next = (currentSlide + dir + total) % total;
    showSlide(next);
  }

  function showSlide(n) {
    // Quita clase active de todos
    slides.forEach(function(s) { s.classList.remove('active'); });
    document.querySelectorAll('.auth-dot').forEach(function(d) { d.classList.remove('active'); });

    currentSlide = n;
    slides[n].classList.add('active');
    document.querySelectorAll('.auth-dot')[n].classList.add('active');

    // Actualiza el texto del slide
    const slide = slides[n];
    document.getElementById('slideTag').textContent   = slide.getAttribute('data-tag')   || '';
    document.getElementById('slideTitle').textContent = slide.getAttribute('data-title') || '';
    document.getElementById('slideDesc').textContent  = slide.getAttribute('data-desc')  || '';
  }
</script>
